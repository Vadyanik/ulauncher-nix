// see the documentation: https://zed.dev/docs/configuring-zed#settings-files
{
  "languages": {
    "Python": {
      "language_servers": [
        "!pylsp",
        "!pyright",
        "!basedpyright",
        "ty",
        "ruff",
        "...",
      ],
      "formatter": {
        "language_server": { "name": "ruff" },
      },
      "code_actions_on_format": {
        "source.fixAll.ruff": true,
      },
    },
  },
}
