{
  "required_api_version": "2.0.0",
  "name": "Nix integration",
  "description": "Look up and run Nix packages",
  "developer_name": "Daste745",
  "icon": "images/icon.png",
  "options": {
    "query_debounce": 0.5
  },
  "preferences": [
    {
      "id": "lookup",
      "type": "keyword",
      "name": "Lookup packages",
      "default_value": "nix"
    },
    {
      "id": "run",
      "type": "keyword",
      "name": "Run nix package",
      "default_value": ","
    },
    {
      "id": "channel",
      "type": "select",
      "name": "Nixpkgs channel",
      "default_value": "unstable",
      "options": ["unstable", "25.05", "25.11"]
    },
    {
      "id": "max_results",
      "type": "input",
      "name": "Max results",
      "default_value": "8"
    }
  ]
}
